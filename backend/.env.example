# 数据库连接 (TiDB Cloud MySQL，本地开发与 Vercel 生产共用)
# 从 TiDB Cloud 控制台或团队密钥获取，禁止提交真实密码
DATABASE_URL=mysql+pymysql://<USER>:<PASSWORD>@<HOST>:4000/talkmate

# TiDB Cloud SSL CA 证书 (Base64 单行编码)
# 本地与 Vercel 均需配置；详见 docs/versions/v0.1.0/deployment/vercel-tidb-ca.md
TIDB_CA_PEM_B64=<BASE64_ENCODED_CA_PEM>

# JWT 配置
JWT_SECRET=please-change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# CORS 允许的源(开发用,生产需要收紧)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 注册验证码(MVP 固定值,4 位数字)
REGISTER_CAPTCHA=1234

# 服务配置
HOST=0.0.0.0
PORT=8000

# DeepSeek AI 配置(由队长单独发 key,通过 setsid env 注入,不要写进 .env)
DEEPSEEK_API_KEY=sk-dummy-replace-via-setsid-env
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=3.0
AI_MAX_HISTORY=20
