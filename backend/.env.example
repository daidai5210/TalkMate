# 数据库连接(SQLite,相对路径)
DATABASE_URL=sqlite:///./talkmate.db

# JWT 配置
JWT_SECRET=please-change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# CORS 允许的源(开发用,生产需要收紧)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 注册验证码(MVP 固定值,4 位数字)
REGISTER_CAPTCHA=1234

# 服务配置
HOST=0.0.0.0
PORT=8000

# DeepSeek AI 配置(由队长单独发 key,通过 setsid env 注入,不要写进 .env)
DEEPSEEK_API_KEY=sk-dummy-replace-via-setsid-env
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=3.0
AI_MAX_HISTORY=20
